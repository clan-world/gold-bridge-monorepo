# Copy this file to .env and fill in real values.
# Never commit .env or private keys.

# Network selection.
# Use Testnet with BaseSepolia first. Use Mainnet with Base only after testing.
WORMHOLE_NETWORK=Testnet
NTT_SOLANA_CHAIN=Solana
NTT_BASE_CHAIN=BaseSepolia

# Existing Solana GOLD token.
SOLANA_TOKEN_MINT=REPLACE_WITH_GOLD_SPL_MINT
SOLANA_TOKEN_DECIMALS=9
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_KEYPAIR_PATH=/absolute/path/to/solana-deployer.json

# NTT project and Solana program keypair.
NTT_PROJECT_DIR=ntt
NTT_SOLANA_PROGRAM_KEYPAIR=keys/ntt-gold-program.json
NTT_SOLANA_PRIORITY_FEE=50000
NTT_SKIP_VERIFY=true

# Base or Base Sepolia.
BASE_RPC_URL=https://sepolia.base.org
BASE_TOKEN_ADDRESS=
BASE_TOKEN_IMPLEMENTATION_ADDRESS=
BASE_PROXY_ADMIN_ADDRESS=
BASE_TIMELOCK_ADDRESS=
BASE_TOKEN_NAME=Gold
BASE_TOKEN_SYMBOL=GOLD
BASE_EXPLORER_URL=https://sepolia.basescan.org

# EVM deployer and upgrade timelock. Use a throwaway key for testnet.
EVM_PRIVATE_KEY=0xREPLACE_ME
EVM_INITIAL_MINTER=0xREPLACE_WITH_TEMPORARY_MINTER
TIMELOCK_PROPOSER=0xREPLACE_WITH_MULTISIG_OR_DEPLOYER
TIMELOCK_EXECUTOR=0x0000000000000000000000000000000000000000
TIMELOCK_ADMIN=0x0000000000000000000000000000000000000000
TIMELOCK_DELAY_SECONDS=86400
BASE_TOKEN_EXPECTED_PROXY=true

# Optional block explorer API keys. NTT CLI may use chain-specific names.
BASESCAN_API_KEY=
BASE_SCAN_API_KEY=
ETHERSCAN_API_KEY=

# Optional: set explicitly if address extraction cannot infer it from ntt/deployment.json.
BASE_NTT_MANAGER_ADDRESS=
SOLANA_NTT_MANAGER_ADDRESS=
BASE_NTT_TRANSCEIVER_ADDRESS=
SOLANA_NTT_TRANSCEIVER_ADDRESS=

# Optional deployment evidence exported by `pnpm artifacts:export`.
SOLANA_DEPLOYER_ADDRESS=
EVM_DEPLOYER_ADDRESS=
BASE_FUNDING_TX=
BASE_TOKEN_DEPLOY_TX=
BASE_SET_MINTER_TX=
SOLANA_TO_BASE_PROOF_TX=
BASE_TO_SOLANA_APPROVE_TX=
BASE_TO_SOLANA_PROOF_TX=

# Optional Base -> Solana recovery helper values.
RECOVERY_DESTINATION_SOLANA_ADDRESS=
RECOVERY_AMOUNT=
RECOVERY_EXECUTE=false
TEST_TRANSFER_DESTINATION_MSG_VALUE=10000000

# Frontend values. The export script can generate these after NTT deployment.
# Vite is configured to read this root .env file.
VITE_WORMHOLE_NETWORK=Testnet
VITE_GOLD_SYMBOL=GOLD
VITE_GOLD_ICON_URL=/gold-token.svg
VITE_SOLANA_TOKEN_MINT=
VITE_SOLANA_TOKEN_DECIMALS=9
VITE_SOLANA_NTT_MANAGER_ADDRESS=
VITE_SOLANA_NTT_TRANSCEIVER_ADDRESS=
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com
VITE_SOLANA_EXPLORER_CLUSTER=devnet
VITE_BASE_CHAIN=BaseSepolia
VITE_BASE_TOKEN_ADDRESS=
VITE_BASE_NTT_MANAGER_ADDRESS=
VITE_BASE_NTT_TRANSCEIVER_ADDRESS=
VITE_BASE_RPC_URL=https://sepolia.base.org
VITE_BASE_EXPLORER_URL=https://sepolia.basescan.org
VITE_WALLET_CONNECT_PROJECT_ID=

# Local operator cockpit API. Keep this bound to localhost unless you add auth.
COCKPIT_API_HOST=127.0.0.1
COCKPIT_API_PORT=8787
COCKPIT_CORS_ORIGIN=http://localhost:5173
VITE_COCKPIT_API_URL=http://127.0.0.1:8787
